# AI-Form Server Configuration Template
# Copy this file to .env and fill in your values

# ===========================================
# Flask Server Settings
# ===========================================

# Enable Flask debug mode (set to 'false' in production)
FLASK_DEBUG=false

# Server host and port
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# ===========================================
# AI Service Configuration
# ===========================================

# API Key for AI service (REQUIRED)
AI_API_KEY=your-api-key-here

# AI Service Base URL
# DeepSeek: https://api.deepseek.com
# Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# AI Model Name
# DeepSeek: deepseek-chat, deepseek-reasoner
# Qwen: qwen-turbo-latest, qwen-plus-latest, qwen-max
AI_MODEL_NAME=qwen-turbo-latest

# Proxy URL (leave empty if not using proxy)
AI_PROXY=http://127.0.0.1:7897

# ===========================================
# Security Settings
# ===========================================

# Maximum request content length in bytes (default: 1MB)
MAX_CONTENT_LENGTH=1048576

# Maximum user input length in characters (default: 10000)
MAX_INPUT_LENGTH=10000

# Maximum context length in characters (default: 50000)
MAX_CONTEXT_LENGTH=50000

# ===========================================
# Rate Limiting
# ===========================================

# Default rate limit for all endpoints
RATE_LIMIT_DEFAULT=100 per hour

# Rate limit for chat endpoint
RATE_LIMIT_CHAT=30 per minute

# ===========================================
# CORS Configuration
# ===========================================

# Allowed origins (comma-separated, use * for all)
CORS_ORIGINS=*

# ===========================================
# Logging
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===========================================
# Authentication Settings
# ===========================================

# JWT Secret Key (IMPORTANT: Change this in production!)
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-secret-in-production

# JWT Access Token Expiration (in seconds)
# Default: 3600 (1 hour)
JWT_ACCESS_TOKEN_EXPIRES=3600

# JWT Refresh Token Expiration (in seconds)
# Default: 2592000 (30 days)
JWT_REFRESH_TOKEN_EXPIRES=2592000

# API Keys for authentication (comma-separated)
# Example: key1,key2,key3
# These keys can be used directly via X-API-Key header
# or exchanged for JWT tokens via /auth/token endpoint
API_KEYS=your-api-key-1,your-api-key-2

# API Key Rate Limit (per minute)
API_KEY_RATE_LIMIT=60 per minute

# ===========================================
# Security Headers Configuration
# ===========================================
# The following security headers are automatically applied to all responses:
# - X-Content-Type-Options: nosniff (prevents MIME type sniffing)
# - X-Frame-Options: DENY (prevents clickjacking)
# - X-XSS-Protection: 1; mode=block (XSS filter for legacy browsers)
# - Strict-Transport-Security: max-age=31536000 (HSTS for HTTPS)
# - Referrer-Policy: strict-origin-when-cross-origin
# - Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
# - Content-Security-Policy: default-src 'self' (CSP for XSS prevention)
# - Cache-Control: no-store, no-cache (prevents caching of API responses)

# ===========================================
# Request Tracing
# ===========================================
# Each request is assigned a unique Request ID for tracing and debugging.
# The Request ID is:
# - Generated automatically if not provided by client
# - Returned in X-Request-ID response header
# - Can be provided by client via X-Request-ID request header

# ===========================================
# Prompt Injection Protection
# ===========================================
# User input is automatically scanned for potential prompt injection patterns.
# Detected patterns include:
# - System prompt manipulation (e.g., "ignore previous instructions")
# - Role manipulation (e.g., "act as", "pretend to be")
# - Output manipulation (e.g., "output the exact", "repeat after me")
# - Instruction injection (e.g., "system:", "[assistant]")
# - Data extraction attempts (e.g., "reveal your instructions")
# - Jailbreak attempts (e.g., "developer mode", "god mode")
#
# When suspicious patterns are detected:
# - The request is still processed (not blocked)
# - A warning is logged with the Request ID
# - Security teams can review logs for potential attacks

# ===========================================
# Security Best Practices
# ===========================================
# 1. NEVER commit .env files with real secrets to version control
# 2. Use strong, unique JWT_SECRET_KEY (32+ bytes of random data)
# 3. Rotate API_KEYS periodically
# 4. In production, set CORS_ORIGINS to specific domains (not *)
# 5. Set FLASK_DEBUG=false in production
# 6. Use HTTPS in production (required for HSTS to work)
# 7. Consider using Redis for rate limiting in multi-worker deployments
# 8. Monitor logs for prompt injection warnings
# 9. Implement IP allowlisting if API should only be accessible from specific networks
# 10. Set up alerting for repeated authentication failures